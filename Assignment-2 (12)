Sum of Each Row and Column


#include <stdio.h>

int main(){
    int a[3][3],i,j,row,col;

    for(i=0;i<3;i++)
        for(j=0;j<3;j++)
            scanf("%d",&a[i][j]);

    for(i=0;i<3;i++){
        row=0;
        for(j=0;j<3;j++)
            row+=a[i][j];
        printf("Row %d Sum = %d\n",i+1,row);
    }

    for(j=0;j<3;j++){
        col=0;
        for(i=0;i<3;i++)
            col+=a[i][j];
        printf("Column %d Sum = %d\n",j+1,col);
    }
}

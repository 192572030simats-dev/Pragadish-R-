Number of Composite Numbers in Array

#include <stdio.h>

int main(){
    int a[]={16,18,27,16,23,21,19};
    int n=7,i,j,count=0,div;

    for(i=0;i<n;i++){
        div=0;
        for(j=1;j<=a[i];j++){
            if(a[i]%j==0)
                div++;
        }
        if(div>2)
            count++;
    }

    printf("Number of Composite Numbers = %d",count);
}

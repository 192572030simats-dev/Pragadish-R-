#include <stdio.h>
#include <math.h>

int main() {
    int x,n,choice;

    printf("Enter two numbers: ");
    scanf("%d%d",&x,&n);

    printf("1.Add\n2.Sub\n3.Mul\n4.Div\n5.Pow\n");
    printf("Enter choice: ");
    scanf("%d",&choice);

    switch(choice)
    {
        case 1: printf("Addition = %d",x+n); break;
        case 2: printf("Subtraction = %d",x-n); break;
        case 3: printf("Multiplication = %d",x*n); break;
        case 4: printf("Division = %d",x/n); break;
        case 5: printf("Power = %.0f",pow(x,n)); break;
        default: printf("Invalid choice");
    }

    return 0;
}

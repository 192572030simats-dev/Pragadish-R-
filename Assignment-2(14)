Second Minimum Element

#include <stdio.h>

int main(){
    int a[]={5,2,8,1,4};
    int i,min=a[0],sec=999;

    for(i=0;i<5;i++){
        if(a[i]<min){
            sec=min;
            min=a[i];
        }
        else if(a[i]<sec && a[i]!=min)
            sec=a[i];
    }

    printf("Second Minimum = %d",sec);
}

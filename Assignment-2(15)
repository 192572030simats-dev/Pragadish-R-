Kth Minimum Element


#include <stdio.h>

int main(){
    int a[]={7,4,2,9,1};
    int i,j,temp,k=3;

    for(i=0;i<5;i++){
        for(j=i+1;j<5;j++){
            if(a[i]>a[j]){
                temp=a[i];
                a[i]=a[j];
                a[j]=temp;
            }
        }
    }

    printf("%dth minimum = %d",k,a[k-1]);

    return 0;
}

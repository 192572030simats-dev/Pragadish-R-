#include <stdio.h>

int main() {
    int num,first,last,temp,digits=0,power=1;

    printf("Enter number: ");
    scanf("%d",&num);

    temp=num;

    last=num%10;

    while(temp>=10)
    {
        temp/=10;
        digits++;
        power*=10;
    }

    first=temp;

    num=num%power;
    num=num/10;

    num=last*power + num*10 + first;

    printf("Result = %d",num);

    return 0;
}
